.profile-page { min-height: 100vh; }
.profile-hero { position: relative; overflow: hidden; padding: 50rpx 32rpx 40rpx; background: #2e6f52; color: #fff; }
.profile-pattern { position: absolute; top: -280rpx; right: -210rpx; width: 600rpx; height: 600rpx; border: 75rpx solid rgba(255,255,255,.06); border-radius: 50%; }
.profile-kicker { position: relative; display: block; color: rgba(255,255,255,.65); font-size: 19rpx; font-weight: 700; letter-spacing: 4rpx; }
.identity-row { position: relative; display: flex; margin-top: 28rpx; align-items: center; }
.profile-avatar { display: flex; width: 104rpx; height: 104rpx; overflow: hidden; align-items: center; justify-content: center; border: 5rpx solid rgba(255,255,255,.25); border-radius: 50%; background: #e9f3ed; color: #28684d; font-size: 38rpx; font-weight: 800; }
.profile-avatar image { width: 100%; height: 100%; }
.identity-copy { min-width: 0; margin-left: 21rpx; flex: 1; }.identity-name, .identity-account { display: block; }.identity-name { overflow: hidden; font-size: 36rpx; font-weight: 800; text-overflow: ellipsis; white-space: nowrap; }.identity-account { margin-top: 4rpx; color: rgba(255,255,255,.68); font-size: 21rpx; }
.edit-button { width: 100rpx; height: 60rpx; margin: 0; border: 1rpx solid rgba(255,255,255,.35); border-radius: 15rpx; background: rgba(255,255,255,.10); color: #fff; font-size: 23rpx; line-height: 58rpx; }
.stats-row { position: relative; display: flex; margin-top: 38rpx; padding-top: 28rpx; border-top: 1rpx solid rgba(255,255,255,.15); }
.stats-row view { flex: 1; text-align: center; }.stats-row view + view { border-left: 1rpx solid rgba(255,255,255,.15); }.stats-row text { display: block; color: rgba(255,255,255,.62); font-size: 19rpx; }.stats-row .stat-number { color: #fff; font-size: 34rpx; font-weight: 700; }
.profile-content { padding-top: 18rpx; }
.error-banner { margin: 12rpx 0; padding: 18rpx; border-radius: 15rpx; background: #fff0ed; color: #a94c43; text-align: center; }
.profile-section { margin-top: 32rpx; }.profile-section-title { display: block; margin: 0 0 13rpx 5rpx; color: #68786f; font-size: 22rpx; font-weight: 650; }
.menu-card { overflow: hidden; padding: 0 24rpx; }
.menu-item { display: flex; min-height: 116rpx; align-items: center; }
.menu-icon { display: flex; width: 62rpx; height: 62rpx; align-items: center; justify-content: center; border-radius: 18rpx; background: #e8f3ec; color: #337555; font-size: 25rpx; font-weight: 750; }.menu-icon.coral { background: #f9ebe6; color: #c7694b; }.menu-icon.sand { background: #f5efe4; color: #9b7650; }.menu-icon.blue { background: #e8f0f2; color: #507580; }
.menu-copy { min-width: 0; margin-left: 20rpx; flex: 1; }.menu-copy text { display: block; }.menu-copy > text:first-child { font-size: 27rpx; font-weight: 650; }.menu-copy .menu-note { margin-top: 3rpx; color: #87938c; font-size: 20rpx; font-weight: 400; }
.menu-arrow { color: #9aa49e; font-size: 38rpx; }.menu-divider { height: 1rpx; margin-left: 82rpx; background: #e8eeea; }
.logout-button { height: 84rpx; margin-top: 34rpx; border: 1rpx solid #ead8d4; border-radius: 20rpx; background: #fff; color: #b65248; font-size: 25rpx; line-height: 82rpx; }
.version { display: block; margin: 25rpx 0 10rpx; color: #a0aaa4; font-size: 19rpx; text-align: center; }
.edit-mask { position: fixed; z-index: 20; inset: 0; background: rgba(22,39,30,.4); }
.edit-sheet { position: fixed; z-index: 21; right: 0; bottom: 0; left: 0; padding: 16rpx 30rpx calc(36rpx + env(safe-area-inset-bottom)); border-radius: 34rpx 34rpx 0 0; background: #fff; transform: translateY(105%); transition: transform .2s ease-out; }.edit-sheet.open { transform: translateY(0); }
.sheet-handle { width: 72rpx; height: 7rpx; margin: 0 auto 25rpx; border-radius: 4rpx; background: #dbe3de; }
.sheet-head { display: flex; align-items: flex-start; justify-content: space-between; }.sheet-title, .sheet-copy { display: block; }.sheet-title { font-size: 34rpx; font-weight: 750; }.sheet-copy { color: #849089; font-size: 21rpx; }.sheet-head button { width: 60rpx; height: 60rpx; margin: 0; border-radius: 50%; background: #edf2ef; color: #607168; font-size: 34rpx; line-height: 56rpx; }
.edit-field { margin-top: 26rpx; }.edit-field text { display: block; margin: 0 0 9rpx 4rpx; color: #5f6e66; font-size: 23rpx; font-weight: 650; }.edit-field input { height: 88rpx; padding: 0 22rpx; border: 1rpx solid #dbe6df; border-radius: 18rpx; background: #fafcfb; }
.edit-error { display: block; margin: 15rpx 4rpx 0; color: #c84c43; font-size: 22rpx; }.save-button { margin-top: 28rpx; }
