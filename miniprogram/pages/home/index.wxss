.home-page { min-height: 100vh; }
.home-hero { position: relative; overflow: hidden; padding: 0 28rpx 42rpx; background: #eaf5ed; }
.hero-background, .hero-overlay { position: absolute; inset: 0; width: 100%; height: 100%; }
.hero-background { opacity: .24; }
.hero-overlay { background: linear-gradient(180deg, rgba(239,248,242,.72), rgba(234,245,237,.94) 70%, #eaf5ed); }
.top-safe, .top-row, .hero-copy, .prompt-box, .suggestion-scroll { position: relative; z-index: 1; }
.top-safe { height: calc(28rpx + env(safe-area-inset-top)); }
.top-row { display: flex; align-items: center; justify-content: space-between; }
.hello { display: block; color: #2b4437; font-size: 27rpx; font-weight: 700; }
.subhello { display: block; margin-top: 2rpx; color: #75847c; font-size: 22rpx; }
.avatar { width: 76rpx; height: 76rpx; border: 4rpx solid rgba(255,255,255,.75); border-radius: 50%; background: #2c7657; color: #fff; font-size: 28rpx; font-weight: 700; line-height: 68rpx; text-align: center; box-shadow: 0 8rpx 22rpx rgba(35,104,77,.17); }
.hero-copy { margin: 62rpx 6rpx 30rpx; }
.hero-kicker { color: #317858; font-size: 22rpx; font-weight: 700; letter-spacing: 3rpx; }
.hero-title { margin-top: 10rpx; color: #24382e; font-size: 53rpx; font-weight: 800; letter-spacing: -3rpx; line-height: 1.2; }
.hero-title text { display: block; color: #277352; }
.prompt-box { padding: 25rpx 24rpx 20rpx; border: 1rpx solid #d1e2d7; border-radius: 28rpx; background: #fff; box-shadow: 0 18rpx 45rpx rgba(35,104,77,.11); }
.prompt-box textarea { width: 100%; min-height: 116rpx; max-height: 220rpx; color: #293a31; font-size: 28rpx; line-height: 1.65; }
.prompt-actions { display: flex; align-items: center; justify-content: space-between; margin-top: 13rpx; }
.location-hint { display: flex; align-items: center; color: #849087; font-size: 22rpx; }
.location-dot { width: 11rpx; height: 11rpx; margin-right: 11rpx; border-radius: 50%; background: #df7655; box-shadow: 0 0 0 6rpx #fae9e3; }
.send-button { width: 104rpx; height: 64rpx; margin: 0; border-radius: 32rpx; background: #23684d; color: #fff; font-size: 25rpx; font-weight: 700; line-height: 64rpx; }
.suggestion-scroll { width: 100%; margin-top: 22rpx; white-space: nowrap; }
.suggestion-row { display: inline-flex; gap: 14rpx; padding-right: 28rpx; }
.suggestion-chip { padding: 14rpx 20rpx; border: 1rpx solid rgba(48,117,87,.16); border-radius: 12rpx; background: rgba(255,255,255,.58); color: #486a58; font-size: 23rpx; }
.content-shell { padding-top: 10rpx; }
.section-eyebrow { display: block; margin-bottom: 4rpx; color: #4b8569; font-size: 19rpx; font-weight: 700; letter-spacing: 3rpx; }
.error-banner { margin-top: 24rpx; padding: 20rpx; border-radius: 18rpx; background: #fff0ed; color: #a84740; text-align: center; }
.city-scroll { width: calc(100% + 28rpx); }
.city-row { display: inline-flex; gap: 18rpx; padding-right: 28rpx; }
.city-card { position: relative; width: 250rpx; height: 320rpx; overflow: hidden; border-radius: 30rpx; background: #dce9e1; }
.city-card image, .city-fallback { width: 100%; height: 100%; }
.city-fallback { display: flex; align-items: center; justify-content: center; background: #79a88e; color: rgba(255,255,255,.72); font-size: 110rpx; font-weight: 800; }
.city-fallback.tone-1 { background: #b4916f; }
.city-fallback.tone-2 { background: #7f98a1; }
.city-shade { position: absolute; inset: 35% 0 0; background: linear-gradient(transparent, rgba(16,39,28,.78)); }
.city-meta { position: absolute; right: 22rpx; bottom: 22rpx; left: 22rpx; }
.city-name { display: block; color: #fff; font-size: 34rpx; font-weight: 800; }
.city-season { display: block; margin-top: 2rpx; overflow: hidden; color: rgba(255,255,255,.78); font-size: 21rpx; text-overflow: ellipsis; white-space: nowrap; }
.loading-row { width: 100%; overflow: hidden; }
.template-list { display: flex; flex-direction: column; gap: 20rpx; }
.template-card { display: flex; overflow: hidden; min-height: 244rpx; }
.template-cover { flex: 0 0 218rpx; width: 218rpx; height: 244rpx; }
.template-fallback { display: flex; align-items: center; justify-content: center; background: #dcebe2; color: #4e8166; font-size: 24rpx; font-weight: 700; letter-spacing: 5rpx; }
.template-body { display: flex; min-width: 0; padding: 24rpx; flex: 1; flex-direction: column; }
.template-top { display: flex; justify-content: space-between; }
.template-days { color: #3c8060; font-size: 19rpx; font-weight: 700; letter-spacing: 2rpx; }
.template-arrow { color: #789087; font-size: 26rpx; }
.template-title { display: block; margin-top: 8rpx; font-size: 29rpx; font-weight: 750; line-height: 1.35; }
.template-summary { display: -webkit-box; margin-top: 9rpx; overflow: hidden; color: #7b8780; font-size: 22rpx; line-height: 1.45; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
.template-tags { display: flex; gap: 12rpx; margin-top: auto; padding-top: 12rpx; }
.template-tags text { padding: 6rpx 10rpx; border-radius: 8rpx; background: #eef5f0; color: #5f796b; font-size: 19rpx; }
