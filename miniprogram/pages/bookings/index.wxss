.bookings-page { padding-top: 36rpx; }
.booking-head { padding: 10rpx 8rpx 30rpx; }
.booking-kicker, .booking-title, .booking-copy { display: block; }
.booking-kicker { color: #408063; font-size: 19rpx; font-weight: 700; letter-spacing: 3rpx; }
.booking-title { margin-top: 9rpx; font-size: 48rpx; font-weight: 800; letter-spacing: -2rpx; }
.booking-copy { max-width: 630rpx; margin-top: 10rpx; color: #76857d; font-size: 23rpx; line-height: 1.65; }
.booking-list, .booking-loading { display: flex; flex-direction: column; gap: 22rpx; }
.booking-card { padding: 28rpx; box-shadow: 0 10rpx 34rpx rgba(37, 78, 57, .06); }
.card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx; }
.destination, .draft-id { display: block; }
.destination { font-size: 31rpx; font-weight: 750; }
.draft-id { max-width: 440rpx; margin-top: 3rpx; overflow: hidden; color: #9aa59f; font-size: 18rpx; text-overflow: ellipsis; white-space: nowrap; }
.status { flex: 0 0 auto; padding: 7rpx 15rpx; border-radius: 999rpx; background: #eef2ef; color: #67756d; font-size: 20rpx; font-weight: 650; }
.status-pending_confirmation { background: #fff1d5; color: #906c18; }
.status-confirmed { background: #e5f4eb; color: #267254; }
.status-cancelled, .status-expired { background: #f2f0ef; color: #847b76; }
.booking-types { margin-top: 22rpx; color: #347458; font-size: 25rpx; font-weight: 700; }
.booking-meta { display: flex; margin-top: 12rpx; justify-content: space-between; color: #7f8b84; font-size: 21rpx; }
.booking-meta text:last-child { color: #4f6057; }
.booking-meta.expiry text:last-child { color: #b36b35; }
.option-box { margin-top: 20rpx; padding: 17rpx 19rpx; border-radius: 15rpx; background: #f5f8f6; }
.option-label, .option-value { display: block; }
.option-label { color: #8a9690; font-size: 18rpx; }
.option-value { margin-top: 4rpx; overflow-wrap: anywhere; color: #55665d; font-size: 20rpx; }
.booking-actions { display: flex; margin-top: 24rpx; gap: 16rpx; }
.booking-actions button { height: 72rpx; margin: 0; border-radius: 18rpx; font-size: 24rpx; line-height: 70rpx; }
.cancel-button { width: 180rpx; border: 1rpx solid #e5d3cf; background: #fff; color: #b45449; }
.confirm-button { background: #286d50; color: #fff; flex: 1; }
.booking-card .line { width: 75%; height: 25rpx; margin: 18rpx 0; }
.booking-card .line.wide { width: 95%; height: 35rpx; }
.booking-card .line.short { width: 45%; }
