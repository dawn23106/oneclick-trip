.ai-page { height: 100vh; overflow: hidden; background: #f6faf7; }
.ai-toolbar { display: flex; height: 112rpx; padding: 16rpx 28rpx; align-items: center; justify-content: space-between; border-bottom: 1rpx solid #e3ebe6; background: rgba(246,250,247,.97); }
.agent-identity { display: flex; align-items: center; gap: 17rpx; }
.agent-mark { position: relative; display: flex; width: 64rpx; height: 64rpx; align-items: center; justify-content: center; border-radius: 50%; background: #23684d; }
.agent-mark::before, .agent-mark::after { position: absolute; width: 20rpx; height: 2rpx; background: rgba(255,255,255,.7); content: ''; }
.agent-mark::after { transform: rotate(90deg); }
.agent-dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: #fff; }
.agent-name, .agent-status { display: block; }
.agent-name { font-size: 27rpx; font-weight: 750; }
.agent-status { color: #7a8880; font-size: 20rpx; }
.toolbar-actions { display: flex; gap: 12rpx; }
.round-action { width: 62rpx; height: 62rpx; margin: 0; padding: 0; border: 1rpx solid #dbe6df; border-radius: 50%; background: #fff; color: #35654e; font-size: 31rpx; line-height: 58rpx; }
.chat-scroll { height: calc(100vh - 112rpx - 186rpx); }
.welcome-panel { padding: 72rpx 42rpx 40rpx; text-align: center; }
.welcome-mark { position: relative; width: 104rpx; height: 104rpx; margin: 0 auto 28rpx; border-radius: 50%; background: #e0f1e6; box-shadow: 0 0 0 16rpx #edf7f0; }
.welcome-mark::after { position: absolute; inset: 27rpx; border: 2rpx solid #4a8b6a; border-radius: 50%; content: ''; }
.welcome-needle { position: absolute; z-index: 1; top: 29rpx; left: 48rpx; width: 9rpx; height: 46rpx; border-radius: 8rpx; background: #2a7354; transform: rotate(36deg); }
.welcome-kicker { display: block; color: #4d8268; font-size: 19rpx; font-weight: 700; letter-spacing: 4rpx; }
.welcome-title { display: block; margin-top: 12rpx; font-size: 44rpx; font-weight: 800; letter-spacing: -2rpx; }
.welcome-copy { display: block; max-width: 570rpx; margin: 16rpx auto 38rpx; color: #748078; font-size: 25rpx; line-height: 1.7; }
.starter-list { display: flex; flex-direction: column; gap: 14rpx; text-align: left; }
.starter-item { display: flex; min-height: 82rpx; padding: 0 24rpx; align-items: center; justify-content: space-between; border: 1rpx solid #dbe7e0; border-radius: 20rpx; background: #fff; color: #3c594a; font-size: 25rpx; }
.message-row { display: flex; gap: 14rpx; padding: 20rpx 28rpx; align-items: flex-start; }
.message-row.user { justify-content: flex-end; }
.message-avatar { flex: 0 0 56rpx; width: 56rpx; height: 56rpx; border-radius: 50%; background: #246a4e; color: #fff; font-size: 21rpx; font-weight: 700; line-height: 56rpx; text-align: center; }
.message-wrap { max-width: 84%; }
.message-bubble { overflow: hidden; padding: 25rpx 27rpx; border: 1rpx solid #dfe8e3; border-radius: 10rpx 28rpx 28rpx 28rpx; background: #fff; box-shadow: 0 7rpx 22rpx rgba(42,75,58,.05); }
.user .message-bubble { border: 0; border-radius: 28rpx 10rpx 28rpx 28rpx; background: #246a4e; color: #fff; }
.user-copy { line-height: 1.65; }
.message-time { display: block; margin: 8rpx 6rpx 0; color: #9aa49e; font-size: 19rpx; }
.user .message-time { text-align: right; }
.thinking { min-width: 360rpx; }
.thinking-dots { display: flex; gap: 7rpx; height: 25rpx; align-items: center; }
.thinking-dots text { width: 8rpx; height: 8rpx; border-radius: 50%; background: #37805f; animation: bounce 1.1s infinite ease-in-out; }
.thinking-dots text:nth-child(2) { animation-delay: .15s; }
.thinking-dots text:nth-child(3) { animation-delay: .3s; }
@keyframes bounce { 0%, 60%, 100% { transform: translateY(0); opacity: .45; } 30% { transform: translateY(-7rpx); opacity: 1; } }
.thinking-stage { display: block; margin-top: 8rpx; color: #315945; font-size: 25rpx; font-weight: 650; }
.thinking-detail { display: block; margin-top: 4rpx; color: #829087; font-size: 21rpx; }
.markdown-body { color: #2e3d35; font-size: 27rpx; line-height: 1.75; }
.markdown-body p { margin: 0 0 16rpx; }
.markdown-body h1, .markdown-body h2, .markdown-body h3 { margin: 18rpx 0 10rpx; color: #20362b; font-weight: 750; }
.markdown-body h1 { font-size: 36rpx; }.markdown-body h2 { font-size: 32rpx; }.markdown-body h3 { font-size: 29rpx; }
.markdown-body strong { color: #1e5f45; font-weight: 750; }
.markdown-body ul, .markdown-body ol { margin: 8rpx 0 18rpx; padding-left: 34rpx; }
.markdown-body li { margin: 7rpx 0; }
.markdown-body code { padding: 3rpx 7rpx; border-radius: 6rpx; background: #edf4ef; color: #315c47; }
.error-bubble { border-color: #efd1cc; background: #fff9f7; }
.error-title, .error-copy { display: block; }
.error-title { color: #b4463e; font-weight: 700; }.error-copy { margin-top: 6rpx; color: #765d58; font-size: 24rpx; }
.retry-button { width: auto; height: 62rpx; margin: 20rpx 0 0; padding: 0 22rpx; border: 1rpx solid #d7e4dc; border-radius: 14rpx; background: #fff; color: #286b50; font-size: 23rpx; line-height: 60rpx; }
.plan-saved { display: flex; margin-top: 12rpx; padding: 18rpx 20rpx; justify-content: space-between; border-radius: 16rpx; background: #e7f4eb; color: #286a4e; font-size: 22rpx; }
.plan-result-card { margin-top: 14rpx; padding: 23rpx; border: 1rpx solid #cfe2d7; border-radius: 23rpx; background: linear-gradient(145deg, #f1f8f3, #fff); box-shadow: 0 10rpx 28rpx rgba(37,91,64,.08); }
.plan-result-head { display: flex; gap: 16rpx; align-items: flex-start; justify-content: space-between; }
.plan-result-kicker, .plan-result-title, .plan-result-meta { display: block; }
.plan-result-kicker { color: #4a8669; font-size: 18rpx; font-weight: 700; letter-spacing: 2rpx; }
.plan-result-title { margin-top: 5rpx; color: #213b2e; font-size: 29rpx; font-weight: 800; }
.plan-result-status { flex: 0 0 auto; padding: 6rpx 11rpx; border-radius: 10rpx; background: #dcefe3; color: #277052; font-size: 18rpx; font-weight: 700; }
.plan-result-meta { margin-top: 8rpx; color: #718179; font-size: 21rpx; }
.plan-result-days { display: flex; margin-top: 18rpx; flex-direction: column; gap: 12rpx; }
.plan-result-day { display: flex; gap: 14rpx; padding-top: 12rpx; border-top: 1rpx solid #e1ebe5; }
.plan-day-label { flex: 0 0 68rpx; color: #438061; font-size: 18rpx; font-weight: 800; letter-spacing: 1rpx; }
.plan-day-copy { min-width: 0; flex: 1; }
.plan-day-title, .plan-day-items { display: block; }
.plan-day-title { color: #30483b; font-size: 22rpx; font-weight: 700; }
.plan-day-items { margin-top: 3rpx; overflow: hidden; color: #839087; font-size: 19rpx; text-overflow: ellipsis; white-space: nowrap; }
.plan-result-button { height: 70rpx; margin: 20rpx 0 0; border-radius: 16rpx; background: #2a7154; color: #fff; font-size: 23rpx; font-weight: 700; line-height: 70rpx; }
.choice-panel { margin-top: 14rpx; padding: 22rpx; border: 1rpx solid #d8e6de; border-radius: 22rpx; background: #fdfefd; box-shadow: 0 8rpx 24rpx rgba(37,91,64,.06); }
.choice-kicker, .choice-title, .choice-prompt { display: block; }
.choice-kicker { color: #3f8061; font-size: 19rpx; font-weight: 700; letter-spacing: 2rpx; }
.choice-title { margin-top: 6rpx; color: #243c30; font-size: 27rpx; font-weight: 750; line-height: 1.4; }
.choice-prompt { margin-top: 8rpx; color: #7a8981; font-size: 21rpx; line-height: 1.55; }
.choice-list { display: flex; margin-top: 17rpx; flex-direction: column; gap: 11rpx; }
.choice-button { display: flex; width: 100%; min-height: 76rpx; margin: 0; padding: 0 20rpx; align-items: center; justify-content: space-between; border: 1rpx solid #dce8e1; border-radius: 16rpx; background: #fff; color: #315746; font-size: 24rpx; font-weight: 650; line-height: 1.3; text-align: left; }
.choice-button.recommended { border-color: #8fc0a5; background: #edf7f1; color: #246a4e; }
.choice-button.selected { border-color: #347a5b; background: #347a5b; color: #fff; }
.choice-button.disabled { opacity: .48; }
.choice-tag { padding: 5rpx 10rpx; border-radius: 9rpx; background: rgba(37,106,78,.1); color: inherit; font-size: 18rpx; font-weight: 700; }
.choice-button.selected .choice-tag { background: rgba(255,255,255,.18); }
.choice-arrow { color: #81958a; font-size: 34rpx; font-weight: 400; }
.chat-bottom { height: 24rpx; }
.composer { position: fixed; z-index: 5; right: 0; bottom: 0; left: 0; height: 186rpx; padding: 18rpx 24rpx 10rpx; border-top: 1rpx solid #e0e9e4; background: rgba(250,252,251,.98); }
.composer-box { display: flex; min-height: 94rpx; padding: 12rpx 12rpx 12rpx 24rpx; align-items: flex-end; gap: 12rpx; border: 1rpx solid #d6e3dc; border-radius: 28rpx; background: #fff; box-shadow: 0 12rpx 35rpx rgba(35,84,60,.08); }
.composer textarea { flex: 1; width: 100%; min-height: 60rpx; max-height: 150rpx; padding: 9rpx 0; font-size: 26rpx; line-height: 1.55; }
.composer-send { flex: 0 0 68rpx; width: 68rpx; height: 68rpx; margin: 0; padding: 0; border-radius: 50%; background: #23684d; color: #fff; font-size: 34rpx; line-height: 65rpx; }
.composer-send.disabled { background: #afc1b7; color: #edf2ef; }
.composer-note { display: block; margin-top: 9rpx; color: #9aa39e; font-size: 18rpx; text-align: center; }
.session-mask { position: fixed; z-index: 20; inset: 0; background: rgba(20,38,29,.38); }
.session-drawer { position: fixed; z-index: 21; top: 0; bottom: 0; left: 0; width: 86%; padding: calc(34rpx + env(safe-area-inset-top)) 26rpx 34rpx; background: #f8fbf9; transform: translateX(-105%); transition: transform .2s ease-out; }
.session-drawer.open { transform: translateX(0); }
.drawer-head { display: flex; align-items: flex-start; justify-content: space-between; }
.drawer-title, .drawer-subtitle { display: block; }.drawer-title { font-size: 38rpx; font-weight: 800; }.drawer-subtitle { color: #809087; font-size: 22rpx; }
.drawer-head button { width: 64rpx; height: 64rpx; margin: 0; border-radius: 50%; background: #eaf1ed; color: #52675c; font-size: 36rpx; line-height: 59rpx; }
.new-session { margin: 30rpx 0 20rpx; }
.session-list { height: calc(100vh - 290rpx); }
.session-item { display: flex; margin-bottom: 12rpx; padding: 21rpx; gap: 14rpx; border: 1rpx solid transparent; border-radius: 20rpx; background: #fff; }
.session-item.active { border-color: #acd0bc; background: #edf7f1; }
.session-copy { min-width: 0; flex: 1; }.session-title, .session-preview { display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.session-title { font-size: 26rpx; font-weight: 650; }.session-preview { margin-top: 5rpx; color: #829087; font-size: 21rpx; }
.session-side { flex: 0 0 78rpx; color: #98a39d; font-size: 18rpx; text-align: right; }
.session-delete { height: 42rpx; margin: 8rpx 0 0 auto; padding: 0; background: transparent; color: #b45c52; font-size: 19rpx; line-height: 42rpx; }
.session-loading, .session-empty { padding: 70rpx 0; color: #8b9891; text-align: center; }
