page {
  --canvas: #f6faf7;
  --surface: #ffffff;
  --ink: #26372f;
  --muted: #718078;
  --primary: #2f8a65;
  --primary-dark: #23684d;
  --primary-soft: #e9f5ee;
  --coral: #df7655;
  --sun: #e5b94f;
  --border: #dfe9e3;
  --error: #c84c43;
  min-height: 100%;
  background: var(--canvas);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.55;
}

view, text, input, textarea, button, image, scroll-view {
  box-sizing: border-box;
}

button::after {
  border: 0;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 28rpx calc(44rpx + env(safe-area-inset-bottom));
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 42rpx 0 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.section-more {
  color: var(--primary-dark);
  font-size: 25rpx;
}

.card {
  border: 1rpx solid var(--border);
  border-radius: 28rpx;
  background: var(--surface);
}

.primary-button,
.secondary-button,
.ghost-button {
  min-height: 88rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 88rpx;
}

.primary-button {
  background: var(--primary-dark);
  color: #fff;
}

.primary-button[disabled] {
  background: #9db8aa;
  color: #eef5f1;
}

.secondary-button {
  border: 1rpx solid #bdd4c7;
  background: var(--primary-soft);
  color: var(--primary-dark);
}

.ghost-button {
  border: 1rpx solid var(--border);
  background: #fff;
  color: var(--ink);
}

.empty-state {
  padding: 86rpx 42rpx;
  text-align: center;
}

.empty-mark {
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 26rpx;
  border-radius: 50%;
  background: var(--primary-soft);
  color: var(--primary-dark);
  font-size: 42rpx;
  line-height: 88rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
}

.empty-copy {
  margin: 12rpx 0 28rpx;
  color: var(--muted);
}

.skeleton {
  border-radius: 12rpx;
  background: linear-gradient(90deg, #eaf0ec 25%, #f5f8f6 38%, #eaf0ec 63%);
  background-size: 400% 100%;
  animation: skeleton 1.2s ease infinite;
}

@keyframes skeleton {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}
