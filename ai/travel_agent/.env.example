APP_ENV=development
INFRA_MODE=auto
BUSINESS_BACKEND=java
JAVA_BACKEND_BASE_URL=http://127.0.0.1:8080
AI_INTERNAL_SERVICE_SECRET=replace-with-a-shared-random-secret
MYSQL_DSN=mysql+aiomysql://user:password@127.0.0.1:3306/oneclick_trip?charset=utf8mb4
REDIS_URL=redis://127.0.0.1:6379/0
CHECKPOINT_TTL_MINUTES=1440
CHECKPOINT_REFRESH_ON_READ=true
CHROMA_PERSIST_DIRECTORY=.data/chroma
CHROMA_SERVER_URL=
CHROMA_COLLECTION=travel_knowledge_bge_v15
EMBEDDING_BACKEND=bge-small-zh-v1.5
BGE_MODEL_DIRECTORY=.data/models/bge-small-zh-v1.5
BGE_AUTO_DOWNLOAD=false
LANGGRAPH_STRICT_MSGPACK=true
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
TOOL_HTTP_TIMEOUT_SECONDS=10
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1
OSRM_BASE_URL=https://router.project-osrm.org
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=oneclick-trip/0.8 (educational travel agent)
# B-02 管理端离线资料采集专用；不会注册到用户运行时。
AGENT_REACH_ENABLED=false
AGENT_REACH_CACHE_TTL_SECONDS=300
AGENT_REACH_RESULT_LIMIT=5
AGENT_REACH_FETCH_TOP=2
XIAOHONGSHU_ENABLED=false
XIAOHONGSHU_RESULT_LIMIT=8
XIAOHONGSHU_DETAIL_LIMIT=2
XIAOHONGSHU_DETAIL_DELAY_SECONDS=2.2
